language = "nodejs"
run = "npm start"
modules = ["nodejs-20"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm start"

[workflows.workflow.metadata]
outputType = "console"

[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["util-linux"]
